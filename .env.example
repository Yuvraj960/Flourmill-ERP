# ============================================================
# MillStream ERP — Root ENV Template
# Copy relevant sections to each service's own .env file
# ============================================================

# --- Shared Database (Supabase) ---
DATABASE_URL=postgresql://<user>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# --- Backend (backend/.env) ---
JWT_SECRET=change_this_to_a_strong_random_secret
PORT=5000

# --- Redis / Upstash (backend/.env) ---
REDIS_URL=rediss://default:<token>@<host>.upstash.io:6379
REDIS_TOKEN=your_upstash_rest_token

# --- Nodemailer / SMTP (backend/.env) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
ADMIN_EMAIL=admin@millstream.local

# --- Frontend (frontend/.env) ---
VITE_API_BASE_URL=http://localhost:5000/api
VITE_AI_SERVICE_URL=http://localhost:8000

# --- AI Service (ai-service/.env) ---
OPENAI_API_KEY=sk-proj-...
COMMODITY_API_KEY=your_alpha_vantage_or_commodity_key
AI_PORT=8000
