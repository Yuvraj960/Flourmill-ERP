# MillStream ERP — AI Microservice Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# =========================================================
# DATABASE
# =========================================================
# Supabase PostgreSQL connection string (Transaction Pooler recommended for serverless)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Read-only database URL for the RAG Text-to-SQL pipeline (restrict to SELECT only)
DATABASE_URL_READONLY=postgresql://readonly_user:password@host:5432/postgres

# =========================================================
# LLM API (for RAG Text-to-SQL)
# =========================================================
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# =========================================================
# COMMODITY API (for Smart Procurement)
# =========================================================
# Alpha Vantage free API key — https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# =========================================================
# CORS / SECURITY
# =========================================================
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# =========================================================
# SERVICE CONFIG
# =========================================================
APP_ENV=development
LOG_LEVEL=info
PORT=8000
