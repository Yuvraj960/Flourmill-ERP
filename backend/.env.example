# ─── Database ───────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string (Transaction Pooler recommended for serverless)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change_me_to_a_long_random_secret_string_256_bits"
JWT_EXPIRES_IN="7d"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Redis / Upstash ─────────────────────────────────────────────────────────
# Upstash Redis TLS URL (format: rediss://:password@host:port)
REDIS_URL="rediss://:[YOUR-REDIS-PASSWORD]@[YOUR-UPSTASH-ENDPOINT]:6380"

# ─── Email / SMTP (Nodemailer) ────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS="your-gmail-app-password"
ADMIN_EMAIL="admin@millstream.com"

# ─── Processing Fee Rates (PKR per kg) ───────────────────────────────────────
FEE_RATE_FLOUR=2.5
FEE_RATE_BRAN=1.0
FEE_RATE_SEMOLINA=3.0

# ─── Admin Bootstrap Credentials (used by seed script) ───────────────────────
ADMIN_PHONE="03000000000"
ADMIN_PASSWORD="AdminPassword@123"
ADMIN_NAME="Mill Admin"
